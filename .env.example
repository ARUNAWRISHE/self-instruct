# ============================================================
# AIDEP — Environment Variables Template
# Copy this to .env and fill in your values.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+psycopg2://aidep:aidep_secret@localhost:5432/aidep_db

# --- LLM Provider ---
# Choose one (or configure multiple — LiteLLM handles routing)
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-...

# Default model (LiteLLM format: "provider/model_name")
# Examples:
#   openai/gpt-4o-mini
#   gemini/gemini-1.5-flash
#   openrouter/openai/gpt-4o
#   mock  (offline dry-run, no key required)
LLM_MODEL=openai/gpt-4o-mini

# --- App Settings ---
APP_ENV=development
APP_DEBUG=true
OUTPUT_DIR=datasets
